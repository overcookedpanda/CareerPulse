# AI provider key — set here or configure from Settings UI
JOBFINDER_ANTHROPIC_API_KEY=

# Optional: AWS credentials for Bedrock provider (or use ~/.aws/credentials)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_DEFAULT_REGION=us-east-1

# Optional: USAJobs.gov API key for federal job listings
JOBFINDER_USAJOBS_API_KEY=

# Data paths
JOBFINDER_DB_PATH=data/jobfinder.db
JOBFINDER_RESUME_PATH=data/resume.txt

# Scraping schedule
JOBFINDER_SCRAPE_INTERVAL_HOURS=6

# Salary filters (jobs below these thresholds are hidden)
JOBFINDER_MIN_SALARY=150000
JOBFINDER_MIN_HOURLY_RATE=95

# Server
JOBFINDER_HOST=0.0.0.0
JOBFINDER_PORT=8085
